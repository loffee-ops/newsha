{
    "name": "backend",
    "private": true,
    "version": "1.0.0",
    "type": "commonjs",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec ts-node --files -r tsconfig-paths/register src/server.ts",
        "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.typecheck.json",
        "start": "node dist/backend/src/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "seed": "tsx -r tsconfig-paths/register src/scripts/db/seed.ts",
        "seed:dev": "tsx -r tsconfig-paths/register src/scripts/db/seed.ts",
        "seed:fresh": "npm run db:reset && npm run seed",
        "seed:admin": "tsx -r tsconfig-paths/register src/scripts/db/seed-admin-run.ts",
        "seed:categories": "tsx -r tsconfig-paths/register src/seed/seed-categories.ts",
        "seed:products": "tsx -r tsconfig-paths/register src/scripts/db/seed-products-run.ts",
        "seed:banners": "tsx -r tsconfig-paths/register src/scripts/db/seed-banners-run.ts",
        "seed:reviews": "tsx -r tsconfig-paths/register src/scripts/db/seed-reviews-run.ts",
        "seed:orders": "tsx -r tsconfig-paths/register src/scripts/db/seed-orders-run.ts",
        "db:reset": "tsx -r tsconfig-paths/register src/scripts/db/reset.ts"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.3.0",
        "@types/supertest": "^6.0.3",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "nodemon": "^3.1.13",
        "supertest": "^7.1.4",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^3.15.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.1",
        "bcryptjs": "^3.0.3",
        "cloudinary": "^2.9.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "google-auth-library": "^10.6.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "module-alias": "^2.3.4",
        "mongoose": "^9.2.1",
        "multer": "^2.0.2",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    }
}
