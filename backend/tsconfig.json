{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "rootDir": "..",
        "outDir": "dist",

        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@shared": ["../shared/src"],
            "@shared/*": ["../shared/src/*"]
        },

        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": ["node", "vitest/globals"],

        "ignoreDeprecations": "5.0"
    },
    "include": ["src", "../shared/src"]
}
